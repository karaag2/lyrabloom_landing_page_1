generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  programs    Program[]
}

model Program {
  id          String   @id @default(uuid())
  title       String
  duration    String   // mapped from "size" / "dimensions"
  description String?
  price       Float?
  image       String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Translation {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  lang      String   @default("fr")
  updatedAt DateTime @updatedAt
}
